# ─────────────────────────────────────────────────────────────────────────────
# Grinta environment variables — see DEPLOYMENT.md for the full workflow.
#
# There are TWO Supabase projects:
#
#   PRODUCTION  → project ref: mmttismftwmgyirzbjhs   (live, paying customers)
#   DEV COPY    → project ref: csnxaznrrojgvwjjpjvw   (safe place to test changes)
#
# App env vars (NEXT_PUBLIC_*) below select WHICH database the running app talks to.
# ─────────────────────────────────────────────────────────────────────────────

# Local development → ALWAYS point at the DEV COPY (never prod) via .env.local
NEXT_PUBLIC_SUPABASE_URL=https://csnxaznrrojgvwjjpjvw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<dev-copy-anon-key>

# Base URL the app uses to build links (invitations, auth email redirects, etc.).
# Local: localhost. Vercel Production scope: https://grintaclub.app
# NOTE: use the public custom domain (grintaclub.app), NOT the vercel.app
# deployment URL — grinta-staged.vercel.app is Deployment-Protected (401),
# so email images and post-confirm redirects break behind it.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production: do NOT put prod keys in a committed/local file.
# Set these in the Vercel dashboard (Project → Settings → Environment Variables,
# Production scope) pointing at https://mmttismftwmgyirzbjhs.supabase.co
#   NEXT_PUBLIC_SUPABASE_URL=https://mmttismftwmgyirzbjhs.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<prod-anon-key>
#   NEXT_PUBLIC_SITE_URL=https://grintaclub.app

# ─────────────────────────────────────────────────────────────────────────────
# Transactional emails (Resend API — separate from Supabase Auth SMTP)
# ─────────────────────────────────────────────────────────────────────────────
# Used only for club invitation emails (player + staff). Auth emails (signup
# confirm, password reset) still go through Supabase Auth's SMTP, which is
# also Resend but configured in supabase/config.toml.
#
# Get the API key from https://resend.com/api-keys (scope: Send only).
# The sender must be on a verified domain (grintaclub.app).
RESEND_API_KEY=re_dev_xxx
RESEND_FROM_EMAIL=Grinta <invitations@grintaclub.app>

# Resend webhook signing secret (https://resend.com/webhooks).
# Configure the webhook URL to https://grintaclub.app/api/webhooks/resend and
# paste the `whsec_…` secret it gives you here.
RESEND_WEBHOOK_SECRET=whsec_xxx

# ─────────────────────────────────────────────────────────────────────────────
# Service-role Supabase key — webhook + cron only, NEVER exposed client-side
# ─────────────────────────────────────────────────────────────────────────────
# Bypasses RLS. Required by /api/webhooks/resend to update email status on
# delivered/bounced/complained events (the webhook isn't an authenticated user).
# In Vercel, set this with the "Sensitive" flag.
SUPABASE_SERVICE_ROLE_KEY=<dev-copy-service-role-key>

# ─────────────────────────────────────────────────────────────────────────────
# Cron jobs (Vercel) — calendar sync, future background jobs
# ─────────────────────────────────────────────────────────────────────────────
# Vercel sends `Authorization: Bearer $CRON_SECRET` when triggering a cron from
# vercel.json. Set the same value in the Vercel Production scope and locally to
# test the route by hand:
#   curl -H "x-cron-secret: $CRON_SECRET" http://localhost:3000/api/cron/calendar-sync
CRON_SECRET=<long-random-string>
