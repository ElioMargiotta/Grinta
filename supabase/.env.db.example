# Postgres connection strings used by the `npm run db:*` migration scripts.
#
# Copy this file to `supabase/.env.db` (gitignored) and fill in the real values.
# Get each string from the Supabase dashboard:
#   Project → Connect → "Session pooler" or "Direct connection" (URI).
#   Replace [YOUR-PASSWORD] with the DB password from Project → Settings → Database.
#
# Then load it before running db scripts:   set -a; . supabase/.env.db; set +a
#
# Use the DIRECT connection (port 5432) for migrations, not the transaction pooler.

# DEV COPY  — project ref csnxaznrrojgvwjjpjvw
SUPABASE_DB_URL_DEV="postgresql://postgres.csnxaznrrojgvwjjpjvw:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres"

# PRODUCTION — project ref mmttismftwmgyirzbjhs   (handle with care)
SUPABASE_DB_URL_PROD="postgresql://postgres.mmttismftwmgyirzbjhs:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Resend SMTP API key — referenced by supabase/config.toml as env(RESEND_API_KEY).
# Must be loaded before `supabase start` / `supabase config push` so the auth
# SMTP block resolves. Create the key at https://resend.com (Domains → API Keys).
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
